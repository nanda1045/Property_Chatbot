APP_ENV=local
LOG_LEVEL=INFO

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=aker_chatbot

CHROMA_PATH=Data/chroma
CHROMA_COLLECTION=property_chunks
BM25_PATH=Data/retrieval/bm25.sqlite3
UNSTRUCTURED_CHUNKS_PATH=Data/unstructured/property_chunks.jsonl
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_PATH=Data/models/sentence-transformers

DEFAULT_PROPERTY_CODE=115r
DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=mock-property-assistant

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
